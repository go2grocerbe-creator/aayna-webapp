# ─── AAYNA backend environment (example) ───
# Copy this file to `.env` and fill in real values. NEVER commit the real .env.

# Required admin credentials (used to seed the dashboard admin account)
ADMIN_EMAIL=your-admin-email@example.com
ADMIN_PASSWORD=change-this-password

# Required: long random secret for signing JWT tokens.
# Generate one with:  python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=replace-with-long-random-secret

# Environment: "development" (default, allows dev fallbacks) or "production" (strict).
# In production the app refuses to start if JWT_SECRET/ADMIN_EMAIL/ADMIN_PASSWORD are
# missing or left at their defaults.
APP_ENV=development

# Database (this app uses MongoDB). DATABASE_URL is an alias for documentation.
DATABASE_URL=
MONGO_URL=mongodb://localhost:27017
DB_NAME=aayna

# CORS allowed origins (comma-separated). Use the real frontend URL in production.
CORS_ORIGINS=*

# Object storage.
# NOTE: This project uses Emergent-managed object storage via EMERGENT_LLM_KEY
# (see EMERGENT_LLM_KEY below). The OBJECT_STORAGE_* keys are placeholders only,
# for teams who later switch to an S3-compatible provider.
OBJECT_STORAGE_BUCKET=
OBJECT_STORAGE_ENDPOINT=
OBJECT_STORAGE_ACCESS_KEY=
OBJECT_STORAGE_SECRET_KEY=
EMERGENT_LLM_KEY=

# Order notification webhook (Milestone 3B).
# When ORDER_WEBHOOK_ENABLED=true and ORDER_WEBHOOK_URL is set, a POST with the
# order payload is sent after each successful order. ORDER_WEBHOOK_SECRET (optional)
# adds an HMAC-SHA256 X-AAYNA-Signature header so the receiver can verify authenticity.
# NEVER commit a real webhook URL or secret.
ORDER_WEBHOOK_URL=
ORDER_WEBHOOK_ENABLED=false
ORDER_WEBHOOK_SECRET=
